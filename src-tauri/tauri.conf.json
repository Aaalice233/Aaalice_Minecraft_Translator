{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aaalice MC Translator",
  "version": "0.2.6",
  "identifier": "com.aaalice.minecraft-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aaalice MC Translator",
        "width": 1365,
        "height": 768,
        "minWidth": 1100,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/i18n-dict/Dict-Sqlite.db",
      "resources/i18n-dict/metadata.json"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/Aaalice233/Aaalice_Minecraft_Translator/releases/latest/download/update.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwMjI3QzcxRjdGQjA3ODcKUldTSEIvdjNjWHdpTURPNnZWbXR4dlRKbXNWTEVYb29DVTkvNWVxaWJOa3IrbkFGUzdPQU1zNVAK"
    }
  }
}
