{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aaalice MC Translator",
  "version": "0.1.0",
  "identifier": "com.aaalice.minecraft-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aaalice MC Translator",
        "width": 1365,
        "height": 768,
        "minWidth": 1100,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
